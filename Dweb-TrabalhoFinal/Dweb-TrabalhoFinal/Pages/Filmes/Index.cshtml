@page
@model Dweb_TrabalhoFinal.Pages.Filmes.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Filmes</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Filme[0].Titulo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Filme[0].Descricao)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Filme[0].Imagem)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Filme[0].Ano)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Filme[0].Duracao)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Filme[0].SessaoFilme)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Filme[0].ListOfGenero)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Filme) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Titulo)
            </td>
            <td>
                @Html.DisplayFor(model => item.Descricao)
            </td>
            <td>
                @Html.DisplayFor(model => item.Imagem)
            </td>
            <td>
                @Html.DisplayFor(model => item.Ano)
            </td>
            <td>
                @Html.DisplayFor(model => item.Duracao)
            </td>
            <td>
                @Html.DisplayFor(model => item.SessaoFilme)
            </td>
            <td>
                @Html.DisplayFor(model => item.ListOfGenero)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
